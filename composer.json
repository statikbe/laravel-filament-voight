{
    "name": "statikbe/laravel-filament-voight",
    "description": "Voight-Kampff test for php and JS dependencies and security vulnerabilities.",
    "keywords": [
        "statikbe",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "laravel-filament-voight"
    ],
    "homepage": "https://github.com/statikbe/laravel-filament-voight",
    "support": {
        "issues": "https://github.com/statikbe/laravel-filament-voight/issues",
        "source": "https://github.com/statikbe/laravel-filament-voight"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Sten Govaerts",
            "email": "sten.govaerts@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "Statikbe\\FilamentVoight\\": "src/",
            "Statikbe\\FilamentVoight\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Statikbe\\FilamentVoight\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Statikbe\\FilamentVoight\\FilamentVoightServiceProvider"
            ],
            "aliases": {
                "FilamentVoight": "Statikbe\\FilamentVoight\\Facades\\FilamentVoight"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}